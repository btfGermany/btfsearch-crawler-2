# Application Settings
APP_NAME=SearchEngine
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# Database Settings
DATABASE_PATH=./data/search.db
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30

# Search Configuration
MAX_RESULTS_PER_PAGE=20
DEFAULT_PAGE_SIZE=10
MAX_SNIPPET_LENGTH=200
EMBEDDINGS_ENABLED=false
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=./data/faiss.index

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Crawler Settings
CRAWLER_USER_AGENT=SearchEngineBot/1.0 (+https://example.com/bot)
CRAWLER_CONCURRENT_REQUESTS=16
CRAWLER_CONCURRENT_REQUESTS_PER_DOMAIN=2
CRAWLER_DOWNLOAD_DELAY=1.0
CRAWLER_RANDOMIZE_DOWNLOAD_DELAY=true
CRAWLER_AUTOTHROTTLE_ENABLED=true
CRAWLER_AUTOTHROTTLE_START_DELAY=1.0
CRAWLER_AUTOTHROTTLE_MAX_DELAY=10.0
CRAWLER_AUTOTHROTTLE_TARGET_CONCURRENCY=2.0
CRAWLER_MAX_DEPTH=3
CRAWLER_TIMEOUT=30
CRAWLER_RETRY_TIMES=3

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# Compliance Settings
ALLOWLIST_PATH=./config/allowlist.txt
BLOCKLIST_PATH=./config/blocklist.txt
ROBOTS_TXT_OBEY=true
RESPECT_CRAWL_DELAY=true
MAX_CRAWL_DELAY=60

# Legal/GDPR
OPERATOR_NAME=Example Company
OPERATOR_ADDRESS=Example Street 1, 12345 City
OPERATOR_EMAIL=legal@example.com
PRIVACY_EMAIL=privacy@example.com
TAKEDOWN_EMAIL=takedown@example.com
IMPRESSUM_URL=/impressum
DATENSCHUTZ_URL=/datenschutz

# Security
CORS_ENABLED=true
CORS_ORIGINS=["http://localhost:3000", "https://example.com"]
SECRET_KEY=change-this-to-a-random-secret-key-in-production
IP_ANONYMIZATION_ENABLED=true
IP_ANONYMIZATION_MASK=255.255.255.0

# Monitoring
METRICS_ENABLED=true
METRICS_PATH=/metrics
HEALTH_CHECK_PATH=/status

# Export Settings
EXPORT_PATH=./exports
MAX_EXPORT_SIZE_MB=1000